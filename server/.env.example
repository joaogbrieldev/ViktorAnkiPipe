# Copia para `.env` e ajusta.
# Valores por omissão estão em `src/config.py` se omitires aqui.

DATABASE_URL=sqlite+aiosqlite:///./data/viktor.db
LIBRETRANSLATE_BASE_URL=http://127.0.0.1:5001
ENVIRONMENT=development

# Uma origem, `*`, ou várias separadas por vírgula; também podes usar JSON: ["http://a","http://b"]
CORS_ORIGINS=*
